# Copy this file to `.env` and fill in your MSB Supabase project values.
# ─── SUPABASE ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → your project → Settings → API
VITE_SUPABASE_PROJECT_ID="your-msb-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-msb-anon-public-key"
VITE_SUPABASE_URL="https://your-msb-project-ref.supabase.co"

# ─── MSB SCHOOL CONFIG ─────────────────────────────────────────────────────────
VITE_SCHOOL_NAME="MSB Private School"
VITE_SCHOOL_SHORT="MSB"
VITE_SCHOOL_EMAIL_DOMAINS="msbdubai.com"
VITE_APP_URL="http://localhost:3000"
